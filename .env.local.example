# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API, used for the 4-week action plan generation
ANTHROPIC_API_KEY=

# Stripe, one-time $15 Pro unlock
# STRIPE_SECRET_KEY is used by the webhook to verify and parse events.
STRIPE_SECRET_KEY=
# Signing secret from the Stripe webhook endpoint (or `stripe listen` locally).
STRIPE_WEBHOOK_SECRET=
# Payment Link created in the Stripe dashboard for the $15 one-time price.
# We append client_reference_id and prefilled_email to it at runtime.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# Base URL, used for auth redirects, the post-payment success page and share links
NEXT_PUBLIC_APP_URL=http://localhost:3000
